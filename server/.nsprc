{
  "1113371": {
    "active": true,
    "notes": "minimatch <10.2.1 ReDoS. Only fixed in minimatch 10+, which introduces breaking changes for glob 7 consumers. We override the direct dependency to minimatch 10+ wherever possible and plan to migrate remaining tooling once upstream releases compatible versions.",
    "expiry": "2026-08-20"
  },
  "1113428": {
    "active": true,
    "notes": "ajv <8.18.0 ReDoS via $data option (GHSA-2g4f-4pwh-qvx6). eslint hard-pins ajv@^6.x and uses it for config validation with trusted input; upgrading requires eslint major bump. Revisit when eslint publishes ajv 8-compatible release.",
    "expiry": "2026-08-20"
  }
}
