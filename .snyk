# Snyk (https://snyk.io) policy file
# For more information, see https://snyk.io/docs/snyk-policy/
version: v1.25.0
ignore:
  SNYK-JS-MINIMATCH-15309438:
    - "*":
        reason: >-
          minimatch@3.1.2 ReDoS: all usages are with hardcoded/trusted input.
          swagger-jsdoc uses glob patterns from source code; sqlite3 uses
          node-gyp glob patterns during native addon compilation. Untrusted
          user input never reaches minimatch. The only fixed version (>=10.2.1)
          is API-incompatible with glob@7 (minimatch 10 CJS export is an
          object, not a function). Will re-evaluate when upstream deps migrate
          to glob@10+ or when minimatch backports a fix to 3.x-9.x.
        expires: 2026-08-20T00:00:00.000Z
        created: 2026-02-20T00:00:00.000Z
  SNYK-JS-AJV-15274295:
    - "*":
        reason: >-
          ajv <8.18.0 ReDoS via $data option. eslint 10 hard-pins ajv@^6.12.4
          and is API-incompatible with ajv 8 (removed draft-04 schema refs,
          changed constructor options). eslint uses ajv only for config schema
          validation with trusted input — not exploitable. Will re-evaluate
          when eslint migrates to ajv 8.
        expires: 2026-08-20T00:00:00.000Z
        created: 2026-02-20T00:00:00.000Z
  SNYK-JS-BRACEEXPANSION-15789759:
    - "*":
        reason: >-
          brace-expansion@1.x Infinite loop via zero-step sequence: introduced
          by swagger-jsdoc > glob@7 > minimatch@3 > brace-expansion@1.1.13.
          Snyk considers all 1.x versions vulnerable (fix requires 5.0.5+), but
          minimatch@3 requires brace-expansion@^1.x (API-incompatible with 5.x
          major). swagger-jsdoc uses glob only to find JSDoc source files at
          build time with hardcoded patterns — untrusted user input never
          reaches this code path. Will re-evaluate when swagger-jsdoc migrates
          to glob@10+.
        expires: 2026-08-20T00:00:00.000Z
        created: 2026-03-27T00:00:00.000Z
